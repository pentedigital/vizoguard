PORT=3000
NODE_ENV=production

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_VPN=price_...              # Basic plan — launch discount ($24.99/yr)
STRIPE_PRICE_SECURITY_VPN=price_...     # Pro plan — launch discount ($99.99/yr)
STRIPE_PRICE_VPN_REGULAR=price_...      # Basic plan — regular ($49.99/yr)
STRIPE_PRICE_SECURITY_VPN_REGULAR=price_...  # Pro plan — regular ($149.99/yr)
LAUNCH_DISCOUNT_END=2026-04-04T23:59:59Z    # After this date, regular prices apply

# SMTP (Hostinger)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=support@vizoguard.com
SMTP_PASS=your-email-password

# App
APP_URL=https://vizoguard.com
DB_PATH=/var/www/vizoguard/data/vizoguard.db

# Outline VPN
OUTLINE_API_URL=https://your-server:port/secret-prefix
